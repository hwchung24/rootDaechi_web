# 배포 시 실제 도메인으로 설정하면 sitemap.xml의 url에 사용됩니다.
# NEXT_PUBLIC_SITE_URL=https://daechiroot.com

# 상담 신청 → Notion DB 저장 (https://www.notion.so/my-integrations 에서 Integration 생성 후)
# NOTION_API_KEY=secret_xxxx
# NOTION_DATABASE_ID=xxxx  (DB 페이지 URL의 ?v= 앞 32자리)

# Notion DB 속성 (영어 이름 그대로 생성):
# Name(제목), Grade, Phone, Channel(선택: 카카오톡/전화 통화/기타), Devices, Concerns, PreferredTime → NOTION_SETUP.md 참고

# 문의하기 페이지 – 카카오톡 플러스 친구 (선택)
# NEXT_PUBLIC_KAKAO_PLUS_FRIEND_URL=https://pf.kakao.com/_xxxxxxxx
# NEXT_PUBLIC_KAKAO_PLUS_FRIEND_NAME=대치루트
